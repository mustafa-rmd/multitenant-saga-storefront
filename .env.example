# Copy this file to .env. The app auto-loads it on startup
# (see config/settings/base.py).

# === Django ===
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=dev-secret-do-not-use-in-prod-xxxxxxxxxxxxxxxxxxxxxxxx
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.acme.test

# === Database (app) ===
# Two URLs: app_user enforces RLS, app_admin bypasses it (used by Celery + admin).
# Hostnames target docker-compose.infra.yml's published ports on localhost.
DATABASE_URL=postgres://app_user:app_user_pass@localhost:5432/acme_cart
DATABASE_ADMIN_URL=postgres://app_admin:app_admin_pass@localhost:5432/acme_cart

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Celery / RabbitMQ ===
CELERY_BROKER_URL=amqp://acme:acme@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# === Stripe (points at stripe-mock for local) ===
STRIPE_API_BASE=http://localhost:12111
STRIPE_UPLOAD_API_BASE=http://localhost:12111
# Test-mode credentials used by scripts/verify_stripe_integration.py.
# Leave as the *_replace_me placeholders for stripe-mock; set to real
# sk_test_* / pk_test_* / whsec_* values to verify against a real Stripe
# test account. NEVER commit real keys.
STRIPE_TEST_SECRET_KEY=sk_test_replace_me
STRIPE_TEST_PUBLIC_KEY=pk_test_replace_me
STRIPE_TEST_WEBHOOK_SECRET=whsec_test_replace_me

# === Admin auth ===
# Token TTL in seconds. Default 8 hours. Set to 0 to disable expiry (tests only).
ADMIN_TOKEN_TTL_SECONDS=28800
# Login rate limits. Liberal defaults for dev/CI (the Bun suite makes ~50
# admin logins from 127.0.0.1 per run); tighten in prod to e.g. 10/min, 5/min.
ADMIN_LOGIN_THROTTLE_RATE_IP=200/min
ADMIN_LOGIN_THROTTLE_RATE_EMAIL=100/min

# === Payments — feature gates ===
# Whether the `mock` gateway is reachable. MUST be False in production to
# prevent a leftover mock config from completing fake checkouts. Defaults
# to DJANGO_DEBUG when unset.
PAYMENTS_ALLOW_MOCK_GATEWAY=True

# === Object storage (invoice PDFs) — MinIO in dev, real S3 in prod ===
# Console: http://localhost:9001 (login: minioadmin / minioadmin)
# Bucket auto-provisioned by docker-compose (MINIO_DEFAULT_BUCKETS).
# To use real AWS S3 instead, clear AWS_S3_ENDPOINT_URL and set the AWS
# region + credentials for your account.
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_REGION_NAME=us-east-1
INVOICE_BUCKET=invoices
MEDIA_BUCKET=media

# === Dev tenant fallback (LOCAL DEVELOPMENT ONLY) ===
# When set and DJANGO_DEBUG=True, requests without a resolvable tenant subdomain
# (e.g. plain http://localhost:8000) fall back to this tenant's subdomain. Lets
# Swagger UI on localhost work without editing the hosts file. Silently ignored
# when DEBUG=False, so it cannot accidentally leak to staging/prod. Never
# overrides a real subdomain.
#
# Authenticated endpoints still require X-Customer-Id pointing at a Customer
# row in the resolved tenant. Use Alice (store-a) or Bob (store-b) from the
# seed script.
DEV_DEFAULT_TENANT_SUBDOMAIN=store-a
